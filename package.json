{
  "name": "llm-chat-history",
  "displayName": "AI Chat History Saver - Auto-export conversations from Cursor, Cline, Kilo & more to Markdown",
  "description": "🚀 Automatically save AI chat history to beautiful Markdown files! Support Cursor IDE and VS Code AI extensions (Cline, Kilo, Blackbox AI). Perfect for knowledge management, team collaboration, and conversation tracking.",
  "version": "0.3.5",
  "publisher": "ClarkZhang",
  "author": {
    "name": "ClarkZhang",
    "email": "857867503@qq.com"
  },
  "bugs": {
    "email": "857867503@qq.com"
  },
  "homepage": "https://llm-chat-history.com/",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Notebooks",
    "Other"
  ],
  "keywords": [
    "cursor",
    "cursor-ide",
    "cline",
    "claude",
    "claude-dev",
    "github-copilot",
    "github-copilot-chat",
    "blackbox-ai",
    "kilo",
    "chatgpt",
    "gpt",
    "openai",
    "anthropic",
    "ai-assistant",
    "coding-assistant",
    "chat",
    "history",
    "conversation",
    "export",
    "backup",
    "markdown",
    "documentation",
    "knowledge-base",
    "team-collaboration",
    "workspace",
    "productivity",
    "logging",
    "archive",
    "record",
    "save-chat",
    "chat-logger",
    "ai-memory",
    "conversation-tracker",
    "llm-history",
    "ai-chat-export",
    "markdown-export",
    "git-friendly",
    "version-control",
    "obsidian",
    "notion",
    "knowledge-management"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Chat History",
      "properties": {
        "chatHistory.autoSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically save chat history"
        },
        "chatHistory.outputDirectory": {
          "type": "string",
          "default": ".llm-chat-history/history",
          "description": "Directory to save chat history files"
        },
        "chatHistory.useUTC": {
          "type": "boolean",
          "default": true,
          "description": "Use UTC timezone for timestamps"
        },
        "chatHistory.locale": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "zh"
          ],
          "default": "auto",
          "description": "Locale for extension messages and markdown (auto/en/zh)"
        },
        "chatHistory.cloudSync.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable cloud synchronization for chat history.\n\n**Note:** You must login to use cloud sync.\n- Click the status bar item `LLM Chat: $(cloud-offline)` in the bottom right corner to login\n- Or use command: `LLMChatHistory: Login to Cloud`\n- View current login status: `LLMChatHistory: Show Cloud Sync Status`"
        },
        "chatHistory.cloudSync.autoSync": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Automatically sync chat history to cloud when logged in.\n\n**Current login status:** Check the status bar item `LLM Chat` in the bottom right corner."
        },
        "chatHistory.cloudSync.debugMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug mode to use custom server URL (for development only)"
        },
        "chatHistory.cloudSync.debugServerUrl": {
          "type": "string",
          "default": "http://192.168.56.101:9999",
          "description": "Custom server URL for debug mode (only works when debugMode is enabled)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "llm-chat-history",
          "title": "LLM Chat History",
          "icon": "resources/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "llm-chat-history": [
        {
          "id": "chatHistoryStatus",
          "name": "Automation"
        },
        {
          "id": "chatHistoryAccount",
          "name": "Account"
        }
      ]
    },
    "commands": [
      {
        "command": "chatHistory.saveNow",
        "title": "LLMChatHistory: Save Chat History Now",
        "icon": "$(save)"
      },
      {
        "command": "chatHistory.search",
        "title": "LLMChatHistory: Search Chat History",
        "icon": "$(search)"
      },
      {
        "command": "chatHistory.cloudLogin",
        "title": "LLMChatHistory: Login to Cloud",
        "icon": "$(sign-in)"
      },
      {
        "command": "chatHistory.cloudLogout",
        "title": "LLMChatHistory: Logout from Cloud",
        "icon": "$(sign-out)"
      },
      {
        "command": "chatHistory.cloudSync",
        "title": "LLMChatHistory: Sync to Cloud Now",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "chatHistory.showCloudStatus",
        "title": "LLMChatHistory: Show Cloud Sync Status"
      },
      {
        "command": "chatHistory.refreshStatus",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "chatHistory.openSettings",
        "title": "Settings",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "chatHistory.refreshStatus",
          "when": "view == chatHistoryStatus",
          "group": "navigation"
        },
        {
          "command": "chatHistory.openSettings",
          "when": "view == chatHistoryStatus",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run setup && npm run rebuild-native && npm run compile && npm run obfuscate",
    "clean": "rimraf dist",
    "prebuild": "npm run check-env",
    "check-env": "node -e \"console.log('Node.js version:', process.version); console.log('Available memory:', Math.round(process.memoryUsage().heapTotal / 1024 / 1024) + 'MB')\"",
    "compile": "tsc -p ./",
    "check-build": "node scripts/check-build.js",
    "obfuscate": "node --max-old-space-size=4096 obfuscate.js",
    "build": "npm run clean && npm run compile && npm run check-build && npm run obfuscate",
    "build:safe": "npm run clean && npm run compile && npm run obfuscate",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "postinstall": "node setup-sqlite.js",
    "setup": "node setup-sqlite.js",
    "download-all-binaries": "node scripts/download-all-binaries.js",
    "rebuild-native": "npm run download-all-binaries && npx electron-rebuild -f -w better-sqlite3",
    "verify": "node verify-setup.js",
    "fix": "node fix-native-module.js",
    "package": "npm run build && npx vsce package",
    "package:test": "node scripts/package-test.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "chokidar": "^3.6.0",
    "prebuild-install": "^7.1.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.93.0",
    "electron": "^39.2.7",
    "javascript-obfuscator": "^4.1.0",
    "rimraf": "^5.0.10",
    "typescript": "^5.0.0"
  }
}
